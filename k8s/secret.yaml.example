# secret.yaml.example — Template for the Kubernetes Secret holding sensitive credentials.
#
# INSTRUCTIONS:
#   1. Copy this file to secret.yaml in the same directory:
#        cp secret.yaml.example secret.yaml
#   2. Fill in the actual secret values below.
#   3. Apply to the cluster:
#        kubectl apply -f k8s/secret.yaml
#   4. NEVER commit secret.yaml to source control.
#      secret.yaml is listed in .gitignore for this reason.
#
# Values use stringData (plain text). Kubernetes will base64-encode them internally.

apiVersion: v1
kind: Secret
metadata:
  name: snow-terraform-agent-secrets
  labels:
    app: snow-terraform-agent
type: Opaque
stringData:
  # Azure OpenAI API key.
  # Only required when AZURE_OPENAI_USE_AZURE_AD=false.
  # Leave empty if authenticating via Azure AD (the default for this deployment).
  AZURE_OPENAI_API_KEY: ""

  # Azure Service Principal client secret.
  # Required when AZURE_OPENAI_USE_AZURE_AD=true so the app can obtain AD tokens.
  # Corresponds to the service principal identified by AZURE_CLIENT_ID in the ConfigMap.
  AZURE_CLIENT_SECRET: ""

  # ServiceNow admin password for the instance at SERVICENOW_INSTANCE_URL.
  SERVICENOW_PASSWORD: ""

  # GitHub Personal Access Token with repo scope.
  # Used by the GitHub MCP server to read/write the Terraform modules repository.
  GITHUB_PERSONAL_ACCESS_TOKEN: ""
