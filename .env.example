# ============================================================
# Snow → Terraform Provisioning Agent  –  .env.example
# Copy to .env and fill in your values
# ============================================================

# ── Azure OpenAI ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.<region>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-nano
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL_NAME=gpt-4.1-nano

# Auth: choose one approach
# true  → uses DefaultAzureCredential (az login / Managed Identity)
# false → uses AZURE_OPENAI_API_KEY below
AZURE_OPENAI_USE_AZURE_AD=true
AZURE_OPENAI_API_KEY=

# ── ServiceNow MCP ───────────────────────────────────────────
# Command to start the ServiceNow MCP server (npm package required)
SNOW_MCP_COMMAND=npx -y @servicenow/now-ai-kit@latest

SERVICENOW_INSTANCE_URL=https://devXXXXXX.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-snow-password

# ── GitHub MCP ───────────────────────────────────────────────
GITHUB_MCP_COMMAND=npx -y @modelcontextprotocol/server-github

# GitHub Personal Access Token — needs: repo, workflow scopes
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# GitHub org/user and Terraform modules repo
GITHUB_ORG=<your-github-org>
GITHUB_TERRAFORM_REPO=terraform-modules-demo

# ── Azure MCP ────────────────────────────────────────────────
AZURE_MCP_SERVER_COMMAND=npx -y @azure/mcp@latest server start

# Target Azure subscription for resource checks
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>

# ── Async / Production mode (optional — omit for local sync mode) ─
# Set these to enable Azure Service Bus + Blob Storage job tracking.
# Without them the agent runs synchronously and returns results inline.
AZURE_SERVICE_BUS_HOSTNAME=<your-namespace>.servicebus.windows.net
AZURE_SERVICE_BUS_QUEUE_NAME=provisioning-queue
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account>
AZURE_STORAGE_CONTAINER_NAME=runs

# ── Observability (optional) ──────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
